APP_NAME="RaeburnAI AgentOS"
APP_URL="http://localhost:3000"
NODE_ENV="development"

# Auth / security
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-with-openssl-rand-base64-32"
ENCRYPTION_KEY="change-me-32-byte-key"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"

# Database
DATABASE_URL="postgresql://agentos:agentos@localhost:5432/agentos?schema=public"

# Model providers - at least one cloud key or OLLAMA_BASE_URL is required for live runs
OPENAI_API_KEY=""
OPENROUTER_API_KEY=""
OLLAMA_BASE_URL="http://localhost:11434"
DEFAULT_MODEL_PROVIDER="ollama"
DEFAULT_MODEL="llama3.1"

# Safety and execution limits
APPROVAL_REQUIRED_FOR_EXTERNAL_ACTIONS="true"
MAX_AGENT_STEPS="12"
MAX_WORKFLOW_RUNTIME_SECONDS="900"
MEMORY_RETENTION_DAYS="365"
API_RATE_LIMIT_PER_MINUTE="60"

# Observability
LOG_LEVEL="info"
METRICS_ENABLED="true"
